<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer glow halo -->
    <path android:pathData="M54,54m-38,0a38,38 0,1 1,76 0a38,38 0,1 1,-76 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="38"
                android:type="radial">
                <item android:color="#2200FF66" android:offset="0.0" />
                <item android:color="#1100FF41" android:offset="0.6" />
                <item android:color="#00000000" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner core glow -->
    <path android:pathData="M54,54m-16,0a16,16 0,1 1,32 0a16,16 0,1 1,-32 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="16"
                android:type="radial">
                <item android:color="#33FFFFFF" android:offset="0.0" />
                <item android:color="#1500FF88" android:offset="0.5" />
                <item android:color="#00000000" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- ════ LONGITUDE LINES (vertical great circles) ════ -->

    <!-- Longitude 0° — full circle (outer rim) -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,54m-26,0a26,26 0,1 1,52 0a26,26 0,1 1,-52 0"
        android:strokeWidth="0.7"
        android:strokeColor="#8800FF66" />

    <!-- Longitude 30° — ellipse -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,28a22.5,26 0,0 1,0 52a22.5,26 0,0 1,0 -52"
        android:strokeWidth="0.6"
        android:strokeColor="#6600FF55" />

    <!-- Longitude 60° — narrower ellipse -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,28a13,26 0,0 1,0 52a13,26 0,0 1,0 -52"
        android:strokeWidth="0.5"
        android:strokeColor="#5500FF44" />

    <!-- Longitude 90° — center vertical line -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,28L54,80"
        android:strokeWidth="0.5"
        android:strokeColor="#4400FF44" />

    <!-- Longitude -30° -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,28a22.5,26 0,0 0,0 52a22.5,26 0,0 0,0 -52"
        android:strokeWidth="0.6"
        android:strokeColor="#6600FF55" />

    <!-- Longitude -60° -->
    <path
        android:fillColor="#00000000"
        android:pathData="M54,28a13,26 0,0 0,0 52a13,26 0,0 0,0 -52"
        android:strokeWidth="0.5"
        android:strokeColor="#5500FF44" />

    <!-- ════ LATITUDE LINES (horizontal circles) ════ -->

    <!-- Equator -->
    <path
        android:fillColor="#00000000"
        android:pathData="M28,54a26,7 0,0 1,52 0a26,7 0,0 1,-52 0"
        android:strokeWidth="0.7"
        android:strokeColor="#8800FF66" />

    <!-- Lat +20° -->
    <path
        android:fillColor="#00000000"
        android:pathData="M30.5,45a23.5,5.5 0,0 1,47 0a23.5,5.5 0,0 1,-47 0"
        android:strokeWidth="0.5"
        android:strokeColor="#6600FF55" />

    <!-- Lat +40° -->
    <path
        android:fillColor="#00000000"
        android:pathData="M35,37a19,4 0,0 1,38 0a19,4 0,0 1,-38 0"
        android:strokeWidth="0.5"
        android:strokeColor="#5500FF44" />

    <!-- Lat -20° -->
    <path
        android:fillColor="#00000000"
        android:pathData="M30.5,63a23.5,5.5 0,0 1,47 0a23.5,5.5 0,0 1,-47 0"
        android:strokeWidth="0.5"
        android:strokeColor="#6600FF55" />

    <!-- Lat -40° -->
    <path
        android:fillColor="#00000000"
        android:pathData="M35,71a19,4 0,0 1,38 0a19,4 0,0 1,-38 0"
        android:strokeWidth="0.5"
        android:strokeColor="#5500FF44" />

    <!-- ════ RIM HIGHLIGHT (bright edge ring) ════ -->
    <path android:pathData="M54,54m-26,0a26,26 0,1 1,52 0a26,26 0,1 1,-52 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="27"
                android:type="radial">
                <item android:color="#00000000" android:offset="0.88" />
                <item android:color="#5500FFAA" android:offset="0.94" />
                <item android:color="#8800FF88" android:offset="0.97" />
                <item android:color="#3300FF66" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Glass specular highlight (top-left) -->
    <path android:pathData="M44,42m-8,0a8,8 0,1 1,16 0a8,8 0,1 1,-16 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="44"
                android:centerY="42"
                android:gradientRadius="8"
                android:type="radial">
                <item android:color="#30FFFFFF" android:offset="0.0" />
                <item android:color="#00FFFFFF" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Aurora band hint (cyan) -->
    <path android:pathData="M42,58m-12,0a12,6 0,1 1,24 0a12,6 0,1 1,-24 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="42"
                android:centerY="58"
                android:gradientRadius="12"
                android:type="radial">
                <item android:color="#1800FFCC" android:offset="0.0" />
                <item android:color="#00000000" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Aurora band hint (green) -->
    <path android:pathData="M62,48m-10,0a10,5 0,1 1,20 0a10,5 0,1 1,-20 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="62"
                android:centerY="48"
                android:gradientRadius="10"
                android:type="radial">
                <item android:color="#1500FF88" android:offset="0.0" />
                <item android:color="#00000000" android:offset="1.0" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
