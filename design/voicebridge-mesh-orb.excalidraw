      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": ["orb_detail"],
      "frameId": null,
      "roundness": null,
      "seed": 401,
      "version": 1,
      "versionNonce": 401,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "3D MESH SPHERE — HOW IT WORKS",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "3D MESH SPHERE — HOW IT WORKS",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "orb_anatomy_desc",
      "type": "text",
      "x": 870,
      "y": 220,
      "width": 340,
      "height": 600,
      "strokeColor": "#888899",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 80,
      "groupIds": ["orb_detail"],
      "frameId": null,
      "roundness": null,
      "seed": 402,
      "version": 1,
      "versionNonce": 402,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "GEOMETRY:\n  - 400+ vertices on a sphere\n  - Using spherical coords (theta, phi)\n  - 12 latitude rings x 24 longitude slices\n  - Each vertex = a small green dot\n  - Lines connect adjacent vertices\n\nRENDERING (Compose Canvas):\n  - 3D→2D perspective projection\n  - Z-depth fades opacity (back = dim)\n  - Wireframe lines at 15% opacity\n  - Vertex dots at 40-80% opacity\n  - Green glow circle behind mesh\n\nANIMATION:\n  IDLE:\n    - Slow Y-axis rotation (20s cycle)\n    - No displacement (perfect sphere)\n    - 30% opacity, subtle\n\n  LISTENING:\n    - Faster rotation (8s cycle)\n    - Perlin noise displacement\n    - Amplitude reactive (voice → blob)\n    - 60% opacity, brighter\n    - Green gradient glow behind\n\n  SPEAKING:\n    - Rhythmic pulsing displacement\n    - Synced to TTS output\n    - Brightest (80% opacity)\n    - Ring particles expand outward\n\n  SENDING:\n    - Compressed sphere (squished)\n    - Orbiting ring of particles\n    - Pulsing glow\n\nCOLOR: Matrix Green #00FF41\n  Glow: #00FF41 at 8-15% alpha\n  Wireframe: #00FF41 at 15-30%\n  Vertices: #00FF41 at 40-80%\n  Background wash: #00FF41 at 5%",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "GEOMETRY:\n  - 400+ vertices on a sphere\n  - Using spherical coords (theta, phi)\n  - 12 latitude rings x 24 longitude slices\n  - Each vertex = a small green dot\n  - Lines connect adjacent vertices\n\nRENDERING (Compose Canvas):\n  - 3D→2D perspective projection\n  - Z-depth fades opacity (back = dim)\n  - Wireframe lines at 15% opacity\n  - Vertex dots at 40-80% opacity\n  - Green glow circle behind mesh\n\nANIMATION:\n  IDLE:\n    - Slow Y-axis rotation (20s cycle)\n    - No displacement (perfect sphere)\n    - 30% opacity, subtle\n\n  LISTENING:\n    - Faster rotation (8s cycle)\n    - Perlin noise displacement\n    - Amplitude reactive (voice → blob)\n    - 60% opacity, brighter\n    - Green gradient glow behind\n\n  SPEAKING:\n    - Rhythmic pulsing displacement\n    - Synced to TTS output\n    - Brightest (80% opacity)\n    - Ring particles expand outward\n\n  SENDING:\n    - Compressed sphere (squished)\n    - Orbiting ring of particles\n    - Pulsing glow\n\nCOLOR: Matrix Green #00FF41\n  Glow: #00FF41 at 8-15% alpha\n  Wireframe: #00FF41 at 15-30%\n  Vertices: #00FF41 at 40-80%\n  Background wash: #00FF41 at 5%",
      "autoResize": true,
      "lineHeight": 1.25
    },

