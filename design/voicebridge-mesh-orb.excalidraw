    {
      "id": "orb_anatomy_title",
      "type": "text",
      "x": 870,
      "y": 180,
      "width": 340,
      "height": 25,
      "strokeColor": "#00FF41",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
